import SwiftUI
import TabularData
    
struct ContentView: View {
    
    @State var yourname: String = ""
    @State var lastname: String = ""
    
    let emptylist2 = ["1","13","12"]
    @State var emptylist = ["1","2"]
    @State var A123 = [3,4,5]
    @State var B123: Int = 0
    
    var body: some View {
        
        VStack {
            
            //This is how you append an integer based on a textbox input
            TextField("Enter an integer", value: $B123, format: .number)
            //.keyboardType(.decimalPad)
                .padding()
                .onSubmit{A123.append(B123)}
                
            List {
                ForEach(A123, id: \.self) { item in
                    Text(item, format: .number)
                }
            }
            //Any time you use an integer you should probably do format .number
            //This is the string version of it
            //Handle1(firstname, lastname)
            TextField("What is your name", text: $yourname)
                .padding()
                .onSubmit{emptylist.append(yourname)}
                .onAppear {
                    loadCSV()
                    //print(dataFrame)
                }

            TextField("Lastname please", text: $lastname)
            Text(yourname)
            
            List {
                ForEach(emptylist, id: \.self) { item in
                    Text(item)
                }
            }
            List {
                ForEach(emptylist2, id: \.self) { item in
                    Text(item)
                }
            }
        }
        
        
        
    }
    
    
        
    }

